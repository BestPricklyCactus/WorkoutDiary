@startuml
title WorkoutDiary - Схема взаимодействия

skinparam backgroundColor white
skinparam componentStyle rectangle
skinparam shadowing false
skinparam defaultFontName Arial

actor User
rectangle "Compose Screen" as UI
rectangle "Store\n(MVI)" as Store
rectangle "ViewState" as State
rectangle "WorkoutRepository" as Repo
rectangle "Room DAO / SQLite" as Room
rectangle "External API\n(OpenRouter, RuStore)" as Api

User --> UI : действие пользователя
UI --> Store : Intent
Store --> State : updateState(...)
State --> UI : render(state)
Store --> UI : one-shot Effect
Store --> Repo : запрос данных / действие
Repo --> Room : локальные данные
Repo --> Api : внешние интеграции

@enduml
